{
  "name": "asom",
  "author": "Kirill Kleimenov",
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "dev:preview": "nuxt dev --envName preview",
    "generate": "nuxt generate",
    "tauri": "tauri",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "format": "npx prettier --write \"**/*.{js,mjs,cjs,ts,mts,cts,vue,json}\"",
    "generate:types": "cd src-tauri && cargo test export_bindings && cd bindings && npx prettier --write \"*.ts\"",
    "test": "vitest run",
    "test:rust": "cd src-tauri && make test",
    "lint": "oxlint --fix --vue-plugin",
    "icon": "npm run tauri icon ./tools/build/icon.png",
    "build": "op run --env-file='.env' --  npx tauri build -v",
    "build:e2e": "cross-env-shell TAURI_E2E_TESTING=true npx tauri build --debug --no-bundle",
    "test:e2e": "nuxt prepare && cross-env-shell TAURI_E2E_TESTING=true wdio run ./wdio.conf.ts"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^4.0.3",
    "@nuxtjs/color-mode": "^4.0.0",
    "@pinia/colada-nuxt": "^1.0.1",
    "@pinia/nuxt": "^0.11.3",
    "@tailwindcss/typography": "^0.5.19",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/webdriverio": "^3.2.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.8.0",
    "@wdio/cli": "^9.27.1",
    "@wdio/local-runner": "^9.27.1",
    "@wdio/mocha-framework": "^9.27.1",
    "@wdio/spec-reporter": "^9.27.1",
    "@wdio/types": "^9.27.1",
    "@wdio/visual-service": "^9.2.2",
    "cross-env": "^10.1.0",
    "expect": "^30.4.1",
    "expect-webdriverio": "^5.6.5",
    "happy-dom": "^20.9.0",
    "nuxt": "^4.4.6",
    "oxlint": "^1.65.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "shadcn-nuxt": "^2.7.3",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7",
    "wdio-nuxt-service": "^1.0.1",
    "wdio-wait-for": "^3.1.1"
  },
  "dependencies": {
    "@lucide/vue": "^1.16.0",
    "@pinia/colada": "^1.3.0",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/match-sorter-utils": "^8.19.4",
    "@tanstack/vue-form": "^1.32.0",
    "@tanstack/vue-table": "^8.21.3",
    "@tanstack/vue-virtual": "^3.13.24",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-sql": "^2.4.0",
    "@tauri-apps/plugin-store": "^2.4.3",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@tiptap/extension-list": "^3.23.4",
