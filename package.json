    "@vueuse/components": "^14.3.0",
    "@vueuse/core": "^14.3.0",
    "clsx": "^2.1.1",
    "cva": "^1.0.0-beta.4",
    "date-fns": "^4.1.0",
    "fuse.js": "^7.3.0",
    "lodash-es": "^4.18.1",
    "motion-v": "^2.2.1",
    "pinia": "^3.0.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "reka-ui": "^2.9.7",
    "short-unique-id": "^5.3.2",
